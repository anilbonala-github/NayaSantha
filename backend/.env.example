# Copy to .env (git-ignored) and fill in. Load into your shell/IDE run config.
# Neon/Supabase give a connection string — convert to JDBC form as below.

# jdbc:postgresql://<host>/<db>?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/nayasantha
SPRING_DATASOURCE_USERNAME=nayasantha
SPRING_DATASOURCE_PASSWORD=nayasantha

# Generate a long random string for anything past local dev.
JWT_SECRET=dev-only-insecure-secret-change-me-0123456789abcdef

# OTP dev stub — any request "succeeds" and this code verifies (no SMS yet).
OTP_DEV_MODE=true
OTP_DEV_CODE=000000

# Optional: server port (default 8080)
# PORT=8080
